# Copy to .env.local and fill in. Used server-side only by /api/transcribe.
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# Used server-side only by /api/community/*. Anon key is safe to expose
# (protected by RLS), but is kept server-only here to match the transcribe route.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=ey...

# Canonical site URL for SEO metadata + sitemap. Optional locally.
NEXT_PUBLIC_SITE_URL=https://your-domain.example
