# Copy to .env.local and fill in. Used server-side only by /api/transcribe.
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# Used server-side only by /api/community/*. Anon key is safe to expose
# (protected by RLS), but is kept server-only here to match the transcribe route.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=ey...

# Canonical site URL for SEO metadata + sitemap. Optional locally.
NEXT_PUBLIC_SITE_URL=https://your-domain.example

# Optional topic generation. In cloud, leave TOPIC_GENERATION_PROVIDER=auto
# and set GROQ_API_KEY above. Locally, auto falls back to Ollama when there is
# no GROQ_API_KEY.
TOPIC_GENERATION_PROVIDER=auto
GROQ_TEXT_MODEL=openai/gpt-oss-20b

# Optional local/self-hosted Ollama topic generation. Defaults shown here.
# Start Ollama locally and pull the model with: ollama pull llama3.2:1b
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:1b
